generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RunStatus {
  queued
  running
  succeeded
  failed
}

enum JobStatus {
  queued
  running
  succeeded
  failed
}

enum Severity {
  critical
  high
  medium
  low
  info
  unknown
}

enum FindingCategory {
  identity
  access
  application_permissions
  tenant_configuration
  audit_and_logging
  data_protection
  device_management
  other
}

enum Confidence {
  low
  medium
  high
}

enum FindingStatus {
  open
  acknowledged
  resolved
  false_positive
}

enum ArtefactType {
  zip
  state
  raw
  log
  csv
  json
}

enum TenantAuthMode {
  MULTI_TENANT_APP
}

model Tenant {
  id            String      @id @default(cuid())
  tenantGuid    String      @unique
  primaryDomain String
  displayName   String?
  auth          TenantAuth? @relation("TenantToAuth")
  tags          String[]    @default([])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  /// Slice 2: org scoping boundary (portal-minted token carries org_id)
  /// Nullable initially for migration/backfill.
  orgId String?

  runs Run[]

  @@index([orgId])
}

model Run {
  id          String    @id @default(cuid())
  tenantId    String
  status      RunStatus @default(queued)
  startedAt   DateTime?
  endedAt     DateTime?
  toolVersion String    @default("0.1.0")
  triggeredBy String?
  modulesEnabled Json   @default("{}")

  /// Data profile for the run
  /// - "safe": summary-only, no PII-heavy artefacts (default)
  /// - "full": explicit opt-in for sensitive exports
  dataProfile String @default("safe")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobs           Job[]
  findings       Finding[]
  observedChecks ObservedCheck[]
  artefacts      Artefact[]

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
}

model Job {
  id        String    @id @default(cuid())
  runId     String
  status    JobStatus @default(queued)
  attempts  Int       @default(0)
  lockedAt  DateTime?
  lockedBy  String?
  lastError String?
  result    Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  findings       Finding[]
  observedChecks ObservedCheck[]
  artefacts      Artefact[]

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  collectorId String @default("entra.users")
  payload     Json?

  @@index([runId, status])
  @@index([collectorId, status])
  @@index([lockedAt])
  @@index([createdAt])
}

model Finding {
  id             String          @id @default(cuid())
  runId          String
  jobId          String?
  checkId        String
  ruleId         String?
  category       FindingCategory @default(other)
  severity       Severity        @default(info)
  confidence     Confidence      @default(medium)
  status         FindingStatus   @default(open)
  score          Int?
  title          String
  description    String
  recommendation String?
  evidence       Json            @default("{}")
  references     Json            @default("[]")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @default(now()) @updatedAt

  run Run  @relation(fields: [runId], references: [id], onDelete: Cascade)
  job Job? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([jobId])
  @@index([severity])
  @@index([category])
  @@index([confidence])
  @@index([status])
  @@index([score])
  @@index([checkId])
  @@index([ruleId])
  @@index([createdAt])
}

/// Observed checks are NOT findings.
/// They store "what was observed" without forcing a pass/fail judgement.
/// The semantic registry for observed checkIds lives in docs/findings-observed-checks.md
///
/// Query patterns we optimize for:
/// - list observed checks for a run: WHERE runId ORDER BY observedAt
/// - slice within a run by collectorId/checkId
model ObservedCheck {
  id String @id @default(cuid())

  runId String
  jobId String?

  /// Stable ID for the observed check (contract)
  checkId String

  /// Collector responsible for the observation (stable collector id)
  collectorId String

  /// Optional rule ID if an observation maps to a rule later
  ruleId String?

  /// When the observation was recorded
  observedAt DateTime @default(now())

  /// Arbitrary JSON payload describing what was seen
  data Json @default("{}")

  /// Optional references (links to artefacts, object IDs, URLs, etc.)
  references Json @default("[]")

  run Run  @relation(fields: [runId], references: [id], onDelete: Cascade)
  job Job? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  // Single-column indexes (useful generally)
  @@index([runId])
  @@index([jobId])
  @@index([checkId])
  @@index([collectorId])
  @@index([ruleId])
  @@index([observedAt])

  // Composite indexes (match real access patterns)
  @@index([runId, observedAt])
  @@index([runId, collectorId])
  @@index([runId, checkId])
}

model Artefact {
  id        String       @id @default(cuid())
  runId     String
  jobId     String?
  type      ArtefactType
  uri       String
  bucket    String
  key       String
  hash      String?
  sizeBytes Int?
  createdAt DateTime @default(now())

  run Run  @relation(fields: [runId], references: [id], onDelete: Cascade)
  job Job? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([jobId])
  @@index([bucket, key])
  @@index([type])
  @@index([createdAt])
}

model TenantAuth {
  id       String         @id @default(cuid())
  tenantId String         @unique
  mode     TenantAuthMode @default(MULTI_TENANT_APP)

  consentedAt DateTime?
  status      String @default("not_connected")
  lastError   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation("TenantToAuth", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status])
}
