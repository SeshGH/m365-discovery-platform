# docker.env.example — template for Docker Compose secrets
#
# Usage:
#   cp docker.env.example .env.docker   (Windows: copy docker.env.example .env.docker)
#   # fill in real values below, then:
#   docker compose --env-file .env.docker up --build
#
# .env.docker is gitignored (.env.* pattern). Never commit real secrets.
# This file (docker.env.example) IS committed — keep it placeholder values only.
#
# This file is intentionally separate from the repo-root .env used by local dev
# so that docker compose --env-file .env.docker never accidentally picks up or
# overwrites local credentials.

# ── Azure app registration (multi-tenant, shared across all customer tenants) ──
GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_SECRET=your-client-secret-here

# ── Portal ↔ API shared JWT secret ──────────────────────────────────────────────
# Must be the same value in both the api and portal services.
# Use any long random string for dev/demo. Change this before any real use.
PORTAL_INTERNAL_JWT_SECRET=dev-secret-change-me-in-production

# ── Organisation ID written into every JWT minted by the portal ─────────────────
# Scopes all tenant data to this org. Use any non-empty string for dev/demo.
PORTAL_DEV_ORG_ID=dev-org
