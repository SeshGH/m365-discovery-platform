# docker.env.example — template for docker compose secrets
# Copy this file to .env at the repo root, then fill in real values.
# The repo root .env is read automatically by docker compose for variable
# substitution (${GRAPH_CLIENT_ID} etc. in docker-compose.yml).
#
# DO NOT commit the filled-in .env — it is already in .gitignore.

# ── Azure app registration (multi-tenant, shared across all customer tenants) ─
GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_SECRET=your-client-secret-here
