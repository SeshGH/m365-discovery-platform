{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,

    // We run via tsx (runtime), same as the worker.
    // Bundler resolution allows bare-specifier imports from workspace packages
    // (e.g. @acme/worker/findings) without requiring .js extensions.
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",

    "noEmit": true,
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
